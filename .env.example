# Neon PostgreSQL connection string
# Get this from: neon.tech → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Resend API key
# Get this from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Your email — the only one allowed to sign in
ALLOWED_EMAIL=mike@example.com

# Frontend URL — used in magic link emails
# Local: http://localhost:5173
# Production: https://money.singledev.eu
FRONTEND_URL=http://localhost:5173

# Allowed CORS origin
# Local: http://localhost:5173
# Production: https://money.singledev.eu
ALLOWED_ORIGIN=http://localhost:5173

# Optional
PORT=3000
LOG_LEVEL=info
